{
  "name": "uc-autopilot",
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js/Ink based UC Autopilot for flicker-free terminal UI - works with any UC-driven project",
  "main": "dist/index.js",
  "bin": {
    "uc-autopilot": "./bin/autopilot.js",
    "autopilot": "./bin/autopilot.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.tsx",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "commander": "^12.1.0",
    "zod": "^3.24.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/node": "^20.0.0",
    "@types/fs-extra": "^11.0.0",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
